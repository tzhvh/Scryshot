<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/home_background"
        app:contentInsetStartWithNavigation="0dp"
        app:contentInsetStart="0dp"
        app:titleMarginStart="0dp"
        android:elevation="2dp"
        app:navigationIcon="@null"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Issue 18: in-app ingestion banner. One container, two states (button-visibility swap,
         not two containers — sharing a dismiss between the idle nudge and the active session is a
         footgun). Mode A (idle + backlog > threshold): title + Index now + Snooze. Mode B (session
         active): title + progress subtitle + Stop. Mounts above the grid; constraintTop is
         re-chained in HomeFragment.renderBanner(). default visibility=gone. -->
    <LinearLayout
        android:id="@+id/ingestion_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primaryTeal"
        android:paddingStart="@dimen/common_padding_16dp"
        android:paddingEnd="@dimen/common_padding_16dp"
        android:paddingTop="@dimen/common_padding_12dp"
        android:paddingBottom="@dimen/common_padding_12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/ingestion_banner_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="@string/ingestion_notification_title"
            tools:text="Indexing screenshots" />

        <TextView
            android:id="@+id/ingestion_banner_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_padding_8dp"
            android:textColor="@color/white"
            android:visibility="gone"
            tools:text="Analyzing 12 of 842" />

        <LinearLayout
            android:id="@+id/ingestion_banner_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_padding_8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/ingestion_banner_action_index"
                style="@android:style/Widget.DeviceDefault.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="@dimen/common_padding_8dp"
                android:paddingEnd="@dimen/common_padding_8dp"
                android:textColor="@color/white"
                android:text="@string/notification_action_index" />

            <Button
                android:id="@+id/ingestion_banner_action_snooze"
                style="@android:style/Widget.DeviceDefault.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/common_padding_8dp"
                android:minWidth="0dp"
                android:paddingStart="@dimen/common_padding_8dp"
                android:paddingEnd="@dimen/common_padding_8dp"
                android:textColor="@color/white"
                android:text="@string/notification_action_snooze" />

            <Button
                android:id="@+id/ingestion_banner_action_stop"
                style="@android:style/Widget.DeviceDefault.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/common_padding_8dp"
                android:minWidth="0dp"
                android:paddingStart="@dimen/common_padding_8dp"
                android:paddingEnd="@dimen/common_padding_8dp"
                android:textColor="@color/white"
                android:text="@string/notification_action_stop" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/main_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/home_background"
        app:layout_constraintTop_toBottomOf="@id/ingestion_banner"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/ingestion_banner"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ViewStub
        android:id="@+id/welcome_stub"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout="@layout/view_welcome"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/onboarding_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="2dp"
        android:visibility="gone">

        <io.github.tzhvh.scryernext.detailpage.GraphicOverlay
            android:id="@+id/onboarding_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/onboarding_guideline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.2" />

        <ImageView
            android:id="@+id/onboarding_image"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/image_searchhint"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/onboarding_guideline" />

        <TextView
            android:id="@+id/onboarding_title"
            style="@style/H2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_padding_20dp"
            android:gravity="center_horizontal"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:text="@string/onboarding_search_title_search"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@+id/onboarding_image" />

        <TextView
            style="@style/Subtitle2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_padding_8dp"
            android:gravity="center_horizontal"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:text="@string/onboarding_search_content_typeword"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@+id/onboarding_title" />

        <TextView
            style="@style/Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/common_padding_24dp"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:text="@string/onboarding_search_caption_battery"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
