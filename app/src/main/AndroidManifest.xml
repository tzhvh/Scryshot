<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Issue 23: notification permission (Android 13+) for ScryerService's capture-result
         notifications. The foreground-service notification itself is exempt by type, but the
         screenshot-detected notification (ScryerService.ID_SCREENSHOT_DETECTED) needs this. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Read access for screenshots the app did not capture itself (foreign captures in
         Pictures/Scryshot/). READ_MEDIA_IMAGES on API 33+, READ_EXTERNAL_STORAGE below.
         Owned here per harmonization; consumed by issue 21's read path. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name="io.github.tzhvh.scryernext.ScryerApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="GoogleAppIndexingWarning">

        <activity
            android:name="io.github.tzhvh.scryernext.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="io.github.tzhvh.scryernext.sortingpanel.SortingPanelActivity"
            android:launchMode="singleTask"
            android:noHistory="false"
            android:taskAffinity="io.github.tzhvh.scryernext.choose_collection"
            android:theme="@style/SortingPanelTheme"
            android:windowSoftInputMode="adjustNothing" />

        <activity
            android:name="io.github.tzhvh.scryernext.detailpage.DetailPageActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/DetailPageTheme" />

        <activity
            android:name="io.github.tzhvh.scryernext.capture.RequestCaptureActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:taskAffinity="io.github.tzhvh.scryernext.request_capture_permission"
            android:theme="@style/Theme.AppCompat.NoActionBar.Translucent" />

        <activity
            android:name="io.github.tzhvh.scryernext.setting.SettingsActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait" />

        <activity
            android:name="io.github.tzhvh.scryernext.SvgViewerActivity"
            android:exported="false" />

        <service
            android:name="io.github.tzhvh.scryernext.ScryerService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- Issue 13: entry point for DiscoveryWorker's notification actions ("Index now"
             enqueues the bulk IngestionWorker; "Snooze" dismisses). Fire-and-forget, no UI.
             Not exported — reachable only via the app's own notification PendingIntents. -->
        <receiver
            android:name="io.github.tzhvh.scryernext.ingestion.triggers.DiscoveryActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="io.github.tzhvh.scryernext.ingestion.action.INDEX_NOW" />
                <action android:name="io.github.tzhvh.scryernext.ingestion.action.SNOOZE" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/fileprovider" />
        </provider>

    </application>
</manifest>
